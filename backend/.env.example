# ==========================================
# VendorBridge Backend - Environment Variables Template
# ==========================================
# Copy this file, rename to .env, and fill in your actual values.
# This file (.env.example) is safe to commit. The real .env is gitignored.

# Server
SERVER_PORT=8080

# MySQL Database
DB_URL=jdbc:mysql://localhost:3306/vendor_bridge?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JWT Configuration
JWT_SECRET=your_base64_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Mail (SMTP credentials)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
